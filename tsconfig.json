{
    "compilerOptions": {
      "target": "ES2023",
      "module": "Node16",
      "moduleResolution": "node16",
      "types": ["node"],
      "declaration": true,
      "outDir": "./dist",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "rootDir": "."
    },
    "include": ["*.ts"],
    "exclude": ["node_modules", "**/__tests__/*"]
  }